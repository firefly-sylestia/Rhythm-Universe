# Rhythm movie/list metadata enrichment
# Android builds read these from the shell environment at Gradle configuration time.
# Do not commit real API keys.

OMDB_API_KEY=YOUR_OMDB_API_KEY_HERE
TMDB_API_KEY=YOUR_TMDB_API_KEY_HERE
TMDB_READ_ACCESS_TOKEN=YOUR_TMDB_READ_ACCESS_TOKEN_HERE

# Compatibility aliases if you reuse web-style environment loaders elsewhere.
VITE_OMDB_API_KEY=YOUR_OMDB_API_KEY_HERE
VITE_TMDB_API_KEY=YOUR_TMDB_API_KEY_HERE
VITE_TMDB_READ_ACCESS_TOKEN=YOUR_TMDB_READ_ACCESS_TOKEN_HERE
NEXT_PUBLIC_OMDB_API_KEY=YOUR_OMDB_API_KEY_HERE
NEXT_PUBLIC_TMDB_API_KEY=YOUR_TMDB_API_KEY_HERE
NEXT_PUBLIC_TMDB_READ_ACCESS_TOKEN=YOUR_TMDB_READ_ACCESS_TOKEN_HERE
